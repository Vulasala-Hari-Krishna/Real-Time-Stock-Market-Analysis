# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicitly declare Python files as text with LF endings
*.py text eol=lf
*.pyi text eol=lf

# Config / CI files
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text eol=lf

# Keep binary files as-is
*.png binary
*.jpg binary
*.ico binary
